# Copy to .env and adjust for your environment. Never commit the real .env.

APP_ENV=dev
APP_VERSION=0.1.0

# Postgres (docker-compose service name "db"; use localhost if running the API outside Docker)
DATABASE_URL=postgresql+psycopg://dossier:dossier@localhost:5432/dossier

# MinIO / S3 (docker-compose service name "minio"; use localhost if running the API outside Docker)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=dossier-artifacts

# LLM — provider-abstracted; model name never hard-coded in business logic
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-5
LLM_API_KEY=

EMBEDDING_PROVIDER=voyage
EMBEDDING_API_KEY=
EMBEDDING_MODEL=voyage-3-lite


